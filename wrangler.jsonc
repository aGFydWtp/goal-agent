{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "goal-agent",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-01",
  "compatibility_flags": ["nodejs_compat"],
  "ai": {
    "binding": "AI",
    "remote": true
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "EvaluationCycleAgent",
        "class_name": "EvaluationCycleAgent"
      },
      {
        "name": "GoalAgent",
        "class_name": "GoalAgent"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["EvaluationCycleAgent", "GoalAgent"]
    }
  ]
}
